# 是否开启访问鉴权（服务端，默认不开启，方便本地使用）
AUTH_ENABLED=false
# 开启鉴权时需要设置一个统一密码（只保存在服务端/容器环境变量里）
AUTH_PASSWORD=
# 登录后会话有效期（天）
AUTH_SESSION_DAYS=7
# 可选：用于签名会话 Cookie（不填则使用 AUTH_PASSWORD）
# AUTH_SECRET=
# 可选：Cookie 名称
# AUTH_COOKIE_NAME=sora2_manager_session_v1

# 上游 sora2api 地址（建议不要带 /v1 前缀）
SORA2API_BASE_URL=http://127.0.0.1:8000
# 上游 sora2api Key（只放服务端）
SORA2API_KEY=
